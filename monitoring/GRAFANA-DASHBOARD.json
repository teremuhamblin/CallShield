{
  "title": "CallShield - Backend Monitoring",
  "panels": [
    {
      "type": "graph",
      "title": "API Requests per Second",
      "targets": [
        {
          "expr": "rate(fastapi_requests_total[1m])"
        }
      ]
    },
    {
      "type": "graph",
      "title": "API Response Time (ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(fastapi_response_duration_seconds_bucket[5m]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active Requests",
      "targets": [
        {
          "expr": "sum(fastapi_requests_in_progress)"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
